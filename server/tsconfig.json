{
  "compilerOptions": {
    "target": "ES2022",

    "module": "NodeNext",

    "moduleResolution": "NodeNext",

    "rootDir": "./src",

    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "typeRoots": ["./src/types", "./node_modules/@types"],

    "types": ["node", "express"]
  },

  "include": [
  "src/**/*"
  ]
}